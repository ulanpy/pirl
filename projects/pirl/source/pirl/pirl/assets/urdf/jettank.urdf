<?xml version="1.0" ?>
<robot name="jettank">
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.4 0.9 0.4 1.0"/>
  </material>

  <!-- Base Footprint -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
  </joint>

  <!-- Base Link (Chassis) -->
  <link name="base_link">
    <inertial>
      <mass value="1.6"/>
      <inertia ixx="0.00449" ixy="0.0" ixz="0.0" iyy="0.01345" iyz="0.0" izz="0.01456"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/base_link.stl"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0004 0.0 0.08684214"/>
      <geometry>
        <box size="0.297 0.145 0.11255"/>
      </geometry>
    </collision>
  </link>

  <!-- Lidar -->
  <link name="lidar_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0157049 0.0 -0.0214732"/>
      <mass value="0.0522536"/>
      <inertia ixx="1.45429E-05" ixy="0.0" ixz="0.0" iyy="1.85619E-05" iyz="0.0" izz="3.10574E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/lidar_link.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/lidar_link.stl"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <!-- Slight upward pitch (~5 deg). Sign is robot-frame dependent. -->
    <origin rpy="0 -0.0436332313 0" xyz="0.0959394 0.0 0.1283962"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Camera -->
  <link name="camera_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0.0002543 0.0 -0.0056908"/>
      <mass value="0.2279804"/>
      <inertia ixx="4.84732E-05" ixy="0.0" ixz="0.0" iyy="0.00040882" iyz="0.0" izz="0.00042955"/>
    </inertial>
    <visual>
      <origin rpy="0 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/depth_camera_link.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/depth_camera_link.stl"/>
      </geometry>
    </collision>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin rpy="-0.0001315 0 0" xyz="0.0288581 0.0 0.2020933"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Back shell -->
  <link name="back_shell_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0000123 0.0 -0.0500523"/>
      <mass value="0.0663479"/>
      <inertia ixx="5.65278E-05" ixy="0.0" ixz="0.0" iyy="4.33741E-05" iyz="0.0" izz="6.86643E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0.0 0"/>
      <geometry>
        <mesh filename="../meshes/back_shell_link.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/back_shell_link.stl"/>
      </geometry>
    </collision>
  </link>
  <joint name="back_shell_joint" type="fixed">
    <origin rpy="-3.1416 0 1.5708" xyz="-0.076481 0.0 0.082796"/>
    <parent link="base_link"/>
    <child link="back_shell_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Track visual (static mesh) -->
  <link name="track_visual">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/wheel.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="track_visual_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="track_visual"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Left drive wheel (sprocket) -->
  <link name="left_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.06 0.121 0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right drive wheel (sprocket) -->
  <link name="right_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin rpy="0 0 0" xyz="-0.06 -0.121 0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front skid (collision-only support to prevent nose diving) -->
  <link name="front_skid">
    <collision>
      <origin rpy="0 0 0" xyz="0.12 0 0.0"/>
      <geometry>
        <box size="0.10 0.10 0.02"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_skid_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_skid"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 0"/>
  </joint>

</robot>
